# Copy this file to `.env` and fill in. `.env` is gitignored.

# REQUIRED: absolute path to the project directory the agent will read/write.
# Pick a fresh checkout that contains no secrets you don't want the LLM
# provider to see. The agent has full read/write within this path.
PROJECT_DIR=/absolute/path/to/your/project

# OPTIONAL: published port on host loopback (default 3456).
# BRIDGE_PORT=3456

# OPTIONAL: name shown in the bridge's banner / QR payload.
# EVEN_TERMINAL_NAME=sandbox

# OPTIONAL: pin to a digest in production. Get from `docker manifest inspect
# node:22-bookworm-slim`. Example:
# BASE_IMAGE_DIGEST=sha256:abcdef...
BASE_IMAGE_DIGEST=

# OPTIONAL: package version to install. Default tracked by Dependabot.
EVEN_TERMINAL_VERSION=0.7.9

# OPTIONAL: image tag the compose stack pulls/builds. CI sets this per release.
IMAGE_TAG=local

# OPTIONAL: resource caps. Defaults are conservative.
# BRIDGE_MEM_LIMIT=2g
# BRIDGE_CPUS=2.0
# PROXY_CPUS=1.0
